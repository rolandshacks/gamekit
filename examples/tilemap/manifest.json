{
    options : {
        title: "Tilemap Demo",
        window_width: 420,
        window_height: 300,
        view_width: 320,
        view_height: 200,
        scaling_mode: "zoom",
        fps: 60,
        //enable_validation_layer: true,
        //enable_api_dump_layer: true
    },

    materials : [
        {
            name : "background",
            blend_mode: "normal",
            vertex_shader: "background",
            fragment_shader: "background_frag",
            shader_input_type: "point"
        },

        {
            name : "tilemap",
            blend_mode: "normal",
            shader_input_type: "tile",
            vertex_shader: "gamekit::tilemap_vertex_shader",
            fragment_shader: "gamekit::tilemap_fragment_shader",
            texture: "tiles",
            texture_binding: 1,
            texture_filtering: false,
            topology: "points"
        }
    ],

    textures : [
        {
            name : "tiles",
            path : "tiles.png"
        }
    ],

    shaders : [
        {
            name : "background",
            path : "background.vert"
        },
        {
            name : "background_frag",
            path : "background.frag"
        }
    ],

    maps : [
        {
            name: "map",
            path: "map.ldtk",
            material: "tilemap",
            uncompressed_layers: ["Tiles"]
        }
	]
}
